{% macro backend_app_locations() %}
    # =========================
    # CORE BACKEND (8000)
    # =========================
    location / {
        proxy_pass http://127.0.0.1:8000;

        proxy_buffering off;
        proxy_http_version 1.1;
        proxy_set_header Connection '';

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    # =========================
    # GEO (8001)
    # =========================
    location /geo/ {
        proxy_pass http://127.0.0.1:8001/;

        proxy_http_version 1.1;
        proxy_redirect off;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    # =========================
    # LLM (8002)
    # =========================
    location /llm/ {
        proxy_pass http://127.0.0.1:8002/;
        proxy_connect_timeout 600s;
        proxy_send_timeout    600s;
        proxy_read_timeout    600s;
        send_timeout          600s;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # =========================
    # MONITORING - Prometheus (9090)
    # =========================
    location /prometheus/ {
        proxy_pass http://127.0.0.1:9090/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # =========================
    # MONITORING - Alertmanager (9093)
    # =========================
    location /alerts/ {
        proxy_pass http://127.0.0.1:9093/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
{% endmacro %}

{% if nginx_le_cert_present | default(false) %}
server {
    listen 443 ssl;
    server_name {{ nginx_server_name }};
    client_max_body_size {{ nginx_client_max_body_size | default('500M') }};
    proxy_read_timeout 600s;

    ssl_certificate     /etc/letsencrypt/live/{{ nginx_server_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ nginx_server_name }}/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

{{ backend_app_locations() }}
}

{% endif %}

# =========================
# HTTP: ACME + (redirect to HTTPS or serve until TLS exists)
# =========================
server {
    listen 80;
    server_name {{ nginx_server_name }}{% if nginx_bind_http_to_inventory_ip | default(false) and ansible_host | default('') | length > 0 %} {{ ansible_host }}{% endif %}{% for _sn in nginx_extra_server_names | default([]) %} {{ _sn }}{% endfor %};
    client_max_body_size {{ nginx_client_max_body_size | default('500M') }};

    location /.well-known/acme-challenge/ {
        root {{ nginx_certbot_webroot | default('/var/www/certbot') }};
    }

{% if nginx_le_cert_present | default(false) %}
    location / {
        return 301 https://$host$request_uri;
    }
{% else %}
    proxy_read_timeout 600s;
{{ backend_app_locations() }}
{% endif %}
}
