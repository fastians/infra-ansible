global:
  resolve_timeout: 5m

{% set telegram_enabled = (alertmanager_telegram_bot_token | default('') | length > 0) and (alertmanager_telegram_chat_id | default('') | length > 0) %}

route:
  group_by: ['alertname', 'instance', 'service', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
{% if telegram_enabled %}
  receiver: 'telegram'
{% else %}
  receiver: 'null'
{% endif %}
  routes: []

receivers:
  - name: 'null'
{% if telegram_enabled %}
  - name: 'telegram'
    webhook_configs:
      - url: 'http://127.0.0.1:5001/webhook'
        send_resolved: true
{% endif %}

inhibit_rules: []
