global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'instance', 'service', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: 'telegram'
  routes: []

receivers:
  - name: 'null'
  - name: 'telegram'
    webhook_configs:
      - url: 'http://127.0.0.1:5001/webhook'
        send_resolved: true

inhibit_rules: []
