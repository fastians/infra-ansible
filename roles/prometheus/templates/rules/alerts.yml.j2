# Prometheus alert rules - fire to Alertmanager (e.g. Telegram)
# Use {% raw %} so Prometheus template syntax {{ $labels.* }} is output literally.
# FastAPI: one named alert per service so Prometheus/Alertmanager/Telegram show which service is down.
groups:
  - name: blackbox
    rules:
      - alert: BlackboxProbeDown
        expr: probe_success{job="blackbox_http_probe"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Blackbox probe down"
          description: "HTTP(S) probe failing for 1m for {% raw %}{{ $labels.instance }}{% endraw %}"

  - name: fastapi
    rules:
      - alert: BackendServerDown
        expr: up{job="fastapi",service="backendserver"} == 0
        for: 1m
        labels:
          severity: critical
          service: backendserver
        annotations:
          summary: "backendserver is down"
          description: "backendserver ({% raw %}{{ $labels.target }}{% endraw %}) has been down for more than 1 minute (no /metrics)."

      - alert: GeoServerDown
        expr: up{job="fastapi",service="geoserver"} == 0
        for: 1m
        labels:
          severity: critical
          service: geoserver
        annotations:
          summary: "geoserver is down"
          description: "geoserver ({% raw %}{{ $labels.target }}{% endraw %}) has been down for more than 1 minute (no /metrics)."

      - alert: LLMServerDown
        expr: up{job="fastapi",service="llmserver"} == 0
        for: 1m
        labels:
          severity: critical
          service: llmserver
        annotations:
          summary: "llmserver is down"
          description: "llmserver ({% raw %}{{ $labels.target }}{% endraw %}) has been down for more than 1 minute (no /metrics)."

      - alert: SalomeServerDown
        expr: up{job="fastapi",service="salomeserver"} == 0
        for: 1m
        labels:
          severity: critical
          service: salomeserver
        annotations:
          summary: "salomeserver is down"
          description: "salomeserver ({% raw %}{{ $labels.target }}{% endraw %}) has been down for more than 1 minute (no /metrics)."

  - name: node
    rules:
      - alert: NodeExporterDown
        expr: up{job="nodes"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Node exporter down"
          description: "Node exporter on {% raw %}{{ $labels.instance }}{% endraw %} unreachable for 1m."

      - alert: HighMemory
        expr: (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) > 0.9
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High memory on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Memory usage above 90% for 5m on {% raw %}{{ $labels.instance }}{% endraw %}"

      - alert: HighCpu
        expr: (1 - avg(rate(node_cpu_seconds_total{mode="idle"}[5m])) by (instance)) > 0.9
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High CPU on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "CPU usage above 90% for 5m on {% raw %}{{ $labels.instance }}{% endraw %}"
