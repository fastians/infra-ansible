# Backend API for GEO → workspace upload-step callbacks (split prod: VPC URL via geo_saas_backend_url).
SAAS_BACKEND_URL={{ geo_saas_backend_url | default('http://127.0.0.1:8000') }}

# GEO CORS: never use "*" with credentials=True. Explicit origins match the SaaS web app.
CORS_ORIGINS=https://{{ primary_domain }},https://www.{{ primary_domain }},https://mek-lab.vercel.app,http://localhost:3000,http://localhost:5173

# load-cad / upload-file performance (explicit so prod matches local code defaults)
GEO_SKIP_STL_CAPTURE=1
GEO_DISABLE_SUBCOMPONENT_JSON=1
GEO_MAX_SUBCOMPONENTS_PER_OBJECT=180
