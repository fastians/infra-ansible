
# Production Environment Variables
ENV=production

# Salome Meca binary path (server path)
SALOME_BIN=/home/{{ app_user }}/salome

# Directory containing Code_Aster `as_run` (required for POST /solving). Example inside SALOME-MECA install:
# CODE_ASTER_BIN=/path/to/salome_meca/appli_Vxxx/tools/Code_Aster_xxxxxxx/bin
CODE_ASTER_BIN={{ salome_code_aster_bin | default('') }}
# Code_Aster profile in .export (stable often missing in LGPL Singularity; use testing).
CODE_ASTER_EXPORT_VERSION={{ salome_code_aster_export_version | default('testing') }}

JOBS_DIR=jobs

# Paths match python_app role: app_base_dir/app_name and extra_dirs under it
JOB_SCRIPTS_DIR={{ app_base_dir }}/{{ app_name }}/job_scripts
JOB_OUTPUTS_DIR={{ app_base_dir }}/{{ app_name }}/job_outputs
BUNDLE_DIR={{ app_base_dir }}/{{ app_name }}/bundles
PROJECT_ROOT={{ app_base_dir }}/{{ app_name }}
