#!/bin/bash
# AWS-specific seeder wrapper (DB seed only — not .env sync; use ./resync-env backendserver when supported).
# Usage: ./seed2 backendserver
#        ./seed2 geoserver
#        ./seed2 llmserver

SERVICE=$1

if [ -z "$SERVICE" ]; then
    echo "Usage: ./seed2 <service>"
    echo ""
    echo "Services: backendserver, geoserver, llmserver"
    echo ""
    echo "Examples:"
    echo "  ./seed2 backendserver"
    exit 1
fi

TARGET="backend-aws"

echo "🌱 Running seeder for $SERVICE on AWS ($TARGET)..."
ansible-playbook -i inventories/prod/hosts.ini playbooks/seed.yml \
    -e service=$SERVICE \
    -e target=$TARGET
