#!/bin/bash
# Log viewer wrapper for Mek-Lab Infrastructure
# Usage: ./scripts/logs <service> [std|aws]

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

SERVICE="${1:-}"
ENV="${2:-std}"

if [ -z "$SERVICE" ] || [ "$SERVICE" = "-h" ] || [ "$SERVICE" = "--help" ]; then
    echo "Mek-Lab Log Viewer"
    echo "Usage: ./scripts/logs <service> [env]"
    echo ""
    echo "Services:"
    echo "  backendserver    (Core API)"
    echo "  geoserver        (GEO Engine)"
    echo "  llmserver        (LLM Agent)"
    echo "  salomeserver     (Salome API)"
    echo ""
    echo "Environments:"
    echo "  std              (Google Cloud - Default)"
    echo "  aws              (Amazon Web Services)"
    echo ""
    echo "Examples:"
    echo "  ./scripts/logs backendserver"
    echo "  ./scripts/logs backendserver aws"
    echo "  ./scripts/logs geoserver std"
    exit 1
fi

AWS_HOST="3.37.166.78"
AWS_USER="ubuntu"
AWS_KEY="${ROOT_DIR}/AWS.pem"

STD_BACKEND_HOST="34.64.140.26"
STD_BACKEND_USER="mateen_fastians"

STD_SALOME_HOST="34.64.150.177"
STD_SALOME_USER="mateen_fastians"

if [ "$ENV" = "aws" ]; then
    HOST=$AWS_HOST
    USER=$AWS_USER
    SSH_OPTS="-i $AWS_KEY -o StrictHostKeyChecking=no"
elif [ "$SERVICE" = "salomeserver" ]; then
    HOST=$STD_SALOME_HOST
    USER=$STD_SALOME_USER
    SSH_OPTS="-o StrictHostKeyChecking=no"
else
    HOST=$STD_BACKEND_HOST
    USER=$STD_BACKEND_USER
    SSH_OPTS="-o StrictHostKeyChecking=no"
fi

echo "🔍 Connecting to $ENV ($HOST) to view logs for '$SERVICE'..."
echo "Press Ctrl+C to stop streaming."
echo ""

ssh $SSH_OPTS -t $USER@$HOST "sudo journalctl -u $SERVICE -f -n 100"
