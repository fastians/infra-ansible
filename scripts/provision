#!/bin/bash
# Quick provisioning wrapper script
# Usage: ./scripts/provision <server> [options]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
INVENTORY="${ROOT_DIR}/inventories/prod/hosts.ini"
SITE_PLAYBOOK="${ROOT_DIR}/site.yml"
PLAYBOOKS_DIR="${ROOT_DIR}/playbooks"
source "${ROOT_DIR}/scripts/lib/load-env.sh"
load_env_profile "${ROOT_DIR}"

mkdir -p "${ROOT_DIR}/.ansible/tmp" "${ROOT_DIR}/.ansible/cp"

run_playbook() {
    local playbook="$1"
    shift
    ansible-playbook -i "$INVENTORY" "$playbook" "$@"
}

show_help() {
    cat << EOF
Server Provisioning Tool

Usage: ./scripts/provision <server|command> [options]

Run site.yml for one server (by name):
  monitoring-server   Monitor (brain + probe) only
  salome-server      Salome app server only
  backend-server     Backend app server only

Examples:
  ./scripts/provision monitoring-server
  ./scripts/provision salome-server -vv
  ./scripts/provision backend-server

Other commands:
  monitor             Same as monitoring-server, uses provision-monitor.yml
  salome              Same as salome-server, uses provision-salome.yml
  backend             Same as backend-server, uses provision-backend.yml
  verify              Verify all servers health
  check <server>      Check one server only
  open-firewall-ports     Open UFW ports (monitor + app servers for Prometheus scrape)
  help                This message

Options:
  --tags <tags>       Run only specific tags
  --skip-tags <tags>  Skip specific tags
  --check             Dry run (don't make changes)
  -v, -vv, -vvv       Verbose output

EOF
}

case "${1:-}" in
    "")
        show_help
        exit 1
        ;;

    monitoring-server)
        shift
        echo "▶ Running site.yml for monitoring-server only"
        run_playbook "$SITE_PLAYBOOK" --limit monitoring-server "$@"
        ;;

    salome-server)
        shift
        echo "▶ Running site.yml for salome-server only"
        run_playbook "$SITE_PLAYBOOK" --limit salome-server "$@"
        ;;

    backend-server)
        shift
        echo "▶ Running site.yml for backend-server only"
        run_playbook "$SITE_PLAYBOOK" --limit backend-server "$@"
        ;;

    monitor)
        shift
        echo "🚀 Provisioning Monitor Server (brain + probe)..."
        run_playbook "${PLAYBOOKS_DIR}/provision-monitor.yml" "$@"
        ;;

    salome)
        shift
        echo "🚀 Provisioning Salome Server..."
        run_playbook "${PLAYBOOKS_DIR}/provision-salome.yml" "$@"
        ;;

    backend)
        shift
        echo "🚀 Provisioning Backend Server..."
        run_playbook "${PLAYBOOKS_DIR}/provision-backend.yml" "$@"
        ;;

    verify)
        shift
        echo "🔍 Verifying All Servers..."
        run_playbook "${PLAYBOOKS_DIR}/verify-servers.yml" "$@"
        ;;

    open-firewall-ports|open-monitoring-ports)
        shift
        echo "🔓 Opening firewall ports (monitor + backend/salome for Prometheus)..."
        run_playbook "${PLAYBOOKS_DIR}/open-firewall-ports.yml" "$@"
        ;;

    check)
        if [ -z "${2:-}" ]; then
            echo "❌ Error: Please specify server (monitoring-server, backend-server, salome-server)"
            exit 1
        fi
        SERVER="$2"
        shift 2
        echo "🔍 Checking $SERVER..."
        run_playbook "${PLAYBOOKS_DIR}/verify-servers.yml" --limit "$SERVER" "$@"
        ;;

    help|--help|-h)
        show_help
        ;;

    *)
        echo "❌ Unknown: '$1'"
        echo ""
        echo "Use a server name: monitoring-server, salome-server, backend-server"
        echo "Or: ./scripts/provision help"
        exit 1
        ;;
esac
