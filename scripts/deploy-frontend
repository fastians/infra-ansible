#!/bin/bash
# Build Mek-Lab simulation SPA and publish to S3 + CloudFront.
#
# Usage (from infra_ansible/):
#   ./scripts/deploy-frontend production
#   ./scripts/deploy-frontend staging
#
# Requires: node/npm, aws CLI, terraform outputs (or env overrides).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
REPO_ROOT="$(cd "${ROOT_DIR}/.." && pwd)"
FRONTEND_DIR="${REPO_ROOT}/MEK_LAB_FRONTEND"
TF_ENV="${1:-production}"
TF_DIR="${REPO_ROOT}/infra_terraform/environments/aws-app-${TF_ENV}"

if [ ! -d "$FRONTEND_DIR" ]; then
  echo "❌ Frontend not found: $FRONTEND_DIR"
  exit 1
fi

ENV_FILE="${REPO_ROOT}/.worksystem/files/.env.frontend.prod"
if [ -f "$ENV_FILE" ]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
  echo "📦 Loaded build env from $ENV_FILE"
else
  echo "⚠️  No $ENV_FILE — using existing shell VITE_* variables"
fi

BUCKET="${FRONTEND_S3_BUCKET:-}"
DIST_ID="${FRONTEND_CLOUDFRONT_ID:-}"

if [ -z "$BUCKET" ] || [ -z "$DIST_ID" ]; then
  if [ ! -d "$TF_DIR" ]; then
    echo "❌ Unknown environment '$TF_ENV' (missing $TF_DIR)"
    exit 1
  fi
  echo "🔍 Reading terraform outputs from $TF_DIR ..."
  BUCKET="${BUCKET:-$(terraform -chdir="$TF_DIR" output -raw frontend_bucket_name 2>/dev/null || true)}"
  DIST_ID="${DIST_ID:-$(terraform -chdir="$TF_DIR" output -raw frontend_cloudfront_distribution_id 2>/dev/null || true)}"
fi

if [ -z "$BUCKET" ] || [ "$BUCKET" = "null" ]; then
  echo "❌ frontend_bucket_name is empty. Set enable_frontend_cdn=true and terraform apply, or export FRONTEND_S3_BUCKET."
  exit 1
fi

if [ -z "$DIST_ID" ] || [ "$DIST_ID" = "null" ]; then
  echo "❌ frontend_cloudfront_distribution_id is empty. Export FRONTEND_CLOUDFRONT_ID or run terraform apply."
  exit 1
fi

echo "🏗️  Building frontend (Vite) ..."
cd "$FRONTEND_DIR"
if [ -f package-lock.json ]; then
  npm ci
else
  npm install
fi
npm run build

echo "☁️  Syncing dist/ → s3://${BUCKET}/"
aws s3 sync dist/ "s3://${BUCKET}/" \
  --delete \
  --cache-control "public,max-age=31536000,immutable" \
  --exclude "index.html" \
  --exclude "*.html"

aws s3 cp dist/index.html "s3://${BUCKET}/index.html" \
  --cache-control "public,max-age=0,must-revalidate" \
  --content-type "text/html"

# Upload other HTML entrypoints if any
for html in dist/*.html; do
  [ -f "$html" ] || continue
  base="$(basename "$html")"
  [ "$base" = "index.html" ] && continue
  aws s3 cp "$html" "s3://${BUCKET}/${base}" \
    --cache-control "public,max-age=0,must-revalidate" \
    --content-type "text/html"
done

echo "🔄 Invalidating CloudFront ${DIST_ID} ..."
INVALIDATION_ID="$(aws cloudfront create-invalidation \
  --distribution-id "$DIST_ID" \
  --paths "/*" \
  --query 'Invalidation.Id' \
  --output text)"

echo "✅ Deploy complete"
echo "   Bucket:       s3://${BUCKET}"
echo "   Invalidation: ${INVALIDATION_ID}"
if [ -d "$TF_DIR" ]; then
  echo "   URLs:"
  terraform -chdir="$TF_DIR" output -json frontend_site_urls 2>/dev/null | python3 -c "import sys,json; [print('  ',u) for u in json.load(sys.stdin)]" 2>/dev/null || true
fi
