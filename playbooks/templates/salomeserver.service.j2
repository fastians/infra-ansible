[Unit]
Description={{ app_description }}
After=network.target

[Service]
Type=simple
User={{ app_user }}
Group={{ app_user }}
WorkingDirectory={{ app_base_dir }}/{{ app_name }}
# Standard PATH so subprocesses (e.g. salome script calling "which") find system tools; .venv last for precedence
Environment="PATH=/usr/local/bin:/usr/bin:/bin:{{ app_base_dir }}/{{ app_name }}/.venv/bin"
Environment="PYTHONPATH={{ app_base_dir }}/{{ app_name }}:{{ app_base_dir }}/{{ app_name }}/app"
# .env lives in app/ so the app can find it when run from repo root
EnvironmentFile={{ app_base_dir }}/{{ app_name }}/app/.env
# Ensure port is free before start (avoids "address already in use" on restart)
ExecStartPre=/bin/sh -c 'fuser -k {{ app_port }}/tcp 2>/dev/null || true; sleep 1'
ExecStart={{ app_base_dir }}/{{ app_name }}/.venv/bin/uvicorn {{ app_entry_point }} --host {{ app_host }} --port {{ app_port }} --workers {{ app_workers }}
TimeoutStopSec=15
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
